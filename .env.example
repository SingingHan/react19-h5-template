# 应用标题（页面 title 可直接读取）
VITE_APP_TITLE=React H5 Template
# 接口超时时间（ms）
VITE_API_TIMEOUT=15000
# 接口基础地址
VITE_API_BASE_URL=https://api.example.com
# 幂等请求失败重试次数
VITE_API_RETRY=1
# 每次重试的基础间隔（ms，按次数递增）
VITE_API_RETRY_DELAY=300
# 刷新 token 接口路径
VITE_API_REFRESH_PATH=/auth/refresh
# 本地开发代理前缀（为空则不启用）
VITE_PROXY_PREFIX=
# 本地开发代理目标地址
VITE_PROXY_TARGET=
